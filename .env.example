# منفذ السيرفر
PORT=4000

# رابط قاعدة البيانات Postgres
DATABASE_URL=postgres://daftar:daftar@localhost:5432/daftar

# لو القاعدة على خدمة سحابية تطلب SSL (مثل Railway/Render/Supabase) خليها true
PGSSL=false

# سر توقيع التوكن — بدّله لسلسلة عشوائية طويلة
JWT_SECRET=change-me-to-a-long-random-string

# معرّف عميل جوجل (نفس اللي بالتطبيق) — اختياري لتفعيل دخول جوجل
GOOGLE_CLIENT_ID=

# كلمة سر لوحة التحكم /admin
ADMIN_PASSWORD=
